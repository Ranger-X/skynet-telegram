# ============================================================================
# skynet-telegram configuration. Copy to `.env` and fill in.
# Only the first two variables are strictly required; everything else has
# sane defaults in config.py / reader/rconfig.py.
# ============================================================================

# --- required ---------------------------------------------------------------
TELEGRAM_BOT_TOKEN=123456:ABC...            # @BotFather
OPENROUTER_API_KEY=sk-or-...                # cloud fallback (free-tier models work)

# --- access control ----------------------------------------------------------
# Comma-separated chat ids the bot serves (DMs included). Empty = serve everything.
TARGET_CHAT_IDS=-1001234567890
# Admin commands (/memload, /memgrind, /memwipe). Defaults to TEASE_EXCLUDE_USER_IDS.
OWNER_USER_IDS=123456789
# Excluded from /tease targeting (usually the owner).
TEASE_EXCLUDE_USER_IDS=123456789
# Usernames whose instructions the persona demonstratively ignores.
BLACKLISTED_USERNAMES=

# --- local model (llama.cpp) --------------------------------------------------
USE_LOCAL_MODEL=true
USE_LOCAL_VISION=true
USE_LOCAL_AUDIO=true
LLAMA_SERVER_EXE=D:\llamacpp\llama-server.exe
LLAMA_MODEL_PATH=D:\models\gemma-4-12b-it-Q4_K_M.gguf
# MUST be the official bf16 projector for gemma-4 (third-party F16 exports are broken).
LLAMA_MMPROJ_PATH=D:\models\mmproj-gemma-4-12B-it-bf16.gguf
LLAMA_SERVER_LOG=D:\llamacpp\server.log
LOCAL_CHAT_URL=http://127.0.0.1:8080/v1/chat/completions
LOCAL_HEALTH_URL=http://127.0.0.1:8080/health

# --- vision grinder (optional, GPU) -------------------------------------------
# Second llama-server with a small tiled-ViT VLM (Qwen3-VL-4B) for mass image->text
# (manga pages, photo memory). When unset/down, vision batches politely fall back to
# the main model. Start/stop with toggle-grinder.cmd.
GRINDER_CHAT_URL=http://127.0.0.1:8081/v1/chat/completions

# --- cloud models (OpenRouter) -------------------------------------------------
OPENROUTER_MODEL=poolside/laguna-xs-2.1:free
OPENROUTER_FALLBACK_MODEL=nvidia/nemotron-3-super-120b-a12b:free
VISION_MODEL=nvidia/nemotron-nano-12b-v2-vl:free
VISION_FALLBACK_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free
SUMMARY_MODEL=nvidia/nemotron-3-nano-30b-a3b:free
SUMMARY_FALLBACK_MODEL=nvidia/nemotron-nano-9b-v2:free
GUARD_MODEL=nvidia/nemotron-3-nano-30b-a3b:free

# --- tools ---------------------------------------------------------------------
# Full ffmpeg build (pip builds lack filters); ffprobe expected next to it.
FFMPEG_EXE=D:\ffmpeg\bin\ffmpeg.exe
FFPROBE_EXE=D:\ffmpeg\bin\ffprobe.exe
# 7-Zip for CBR (RAR) comics.
SEVEN_ZIP_EXE=C:\Program Files\7-Zip\7z.exe

# --- proactive features (minutes; 0 = off; runtime-tunable via /time) -----------
TEASE_INTERVAL_SECONDS=0
REACT_INTERVAL_SECONDS=0
HORN_INTERVAL_SECONDS=0
NEWS_INTERVAL_SECONDS=0
TEASE_SEED_USERNAMES=

# --- language ------------------------------------------------------------------
# Default for chats that never ran /lang. Per-chat choice is stored in lang_state.json.
DEFAULT_LANG=en
# /new pulls a real headline from an RSS feed matching the chat's language.
# Set NEWS_FEED_URL to force ONE feed for every language (any RSS works).
# NEWS_FEED_URL=
# NEWS_FEED_URL_EN=https://news.google.com/rss?hl=en-US&gl=US&ceid=US:en
# NEWS_FEED_URL_RU=https://news.google.com/rss?hl=ru&gl=RU&ceid=RU:ru

# --- reader tuning (measured on Ryzen 5600H; re-measure on your box) ------------
READER_PREFILL_TOK_S=18.9
READER_DECODE_TOK_S=4.8
READER_CONTEXT_TOKENS=2200
READER_ANSWER_MAX_TOKENS=300
READER_ANSWER_MAX_TOKENS_GLOBAL=550
READER_RERANK=true
READER_MIN_SCORE=0.30
